{
  "name": "hiking-society",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "postinstall": "pnpx husky",
    "dev": "vite dev --port 3000",
    "generate-routes": "tsr generate",
    "build": "vite build",
    "start": "vite preview",
    "test": "vitest run --config vitest.config.ts",
    "format": "biome format",
    "lint": "biome lint && tsc --noEmit && pnpm check-architecture",
    "check": "biome check --write --unsafe",
    "check-architecture": "pnpm check-architecture:dependencies && pnpm check-architecture:patterns",
    "check-architecture:dependencies": "depcruise --config .dependency-cruiser.mjs src",
    "check-architecture:patterns": "bash scripts/check-architecture-patterns.sh",
    "api:sync": "openapi-typescript http://localhost:3000/api/swagger -o ./src/api/schema.d.ts",
    "find-deadcode": "bash scripts/find-deadcode.sh",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1078.0",
    "@aws-sdk/s3-request-presigner": "^3.1079.0",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@hono/zod-openapi": "^1.4.0",
    "@hono/zod-validator": "^0.8.0",
    "@jsquash/webp": "^1.5.0",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-popover": "^1.1.18",
    "@radix-ui/react-select": "^2.3.2",
    "@react-oauth/google": "^0.13.5",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "1.170.17",
    "@tanstack/react-router-ssr-query": "1.167.1",
    "@tanstack/react-start": "1.168.27",
    "@webtui/css": "^0.1.9",
    "@webtui/plugin-nf": "^0.1.2",
    "@webtui/theme-catppuccin": "^0.0.5",
    "@webtui/theme-everforest": "^0.0.5",
    "@webtui/theme-gruvbox": "^0.0.3",
    "@webtui/theme-nord": "^0.0.4",
    "@webtui/theme-osmium": "^0.0.1",
    "@webtui/theme-vitesse": "^0.0.3",
    "dayjs": "^1.11.21",
    "dotenv": "^17.4.2",
    "drizzle-orm": "1.0.0-rc.4",
    "exifreader": "^4.41.0",
    "google-auth-library": "^10.9.0",
    "heic-convert": "^2.1.0",
    "hono": "^4.12.27",
    "husky": "^9.1.7",
    "inversify-typesafe": "^0.5.4",
    "inversify-typesafe-spring-like": "^0.5.5",
    "jose": "^6.2.3",
    "lint-staged": "^17.0.8",
    "lucide-react": "^1.23.0",
    "maplibre-gl": "^5.24.0",
    "nitro": "npm:nitro-nightly@3.0.1-20260707-232134-a13bd4ee",
    "openapi-fetch": "^0.17.0",
    "openapi-react-query": "^0.5.4",
    "pg": "^8.22.0",
    "prettier": "^3.9.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "^2.0.7",
    "ts-prune": "^0.10.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/vite": "4.3.2",
    "@tanstack/router-cli": "1.167.18",
    "@tanstack/router-plugin": "1.168.19",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "6.0.3",
    "dependency-cruiser": "^18.0.0",
    "drizzle-kit": "1.0.0-rc.4",
    "eslint": "^9",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vite": "8.1.3",
    "vitest": "^4.1.10"
  }
}
